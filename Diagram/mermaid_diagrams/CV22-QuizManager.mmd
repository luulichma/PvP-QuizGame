flowchart TD
    A([" StartQuiz() được gọi\nbởi GameManager"]) --> B["📋 Load câu hỏi từ\nQuizDatabase (ScriptableObject)"]
    B --> C{"QuizDatabase\nrỗng?"}
    C -->|"Có"| ERR(["❌ LogError &\nDừng lại"])
    C -->|"Không"| D["🔀 Fisher-Yates Shuffle\nXáo trộn danh sách câu hỏi"]
    D --> E["🔁 Reset _currentIndex = -1"]
    E --> F["➡️ Gọi NextQuestion()"]

    F --> G["📈 _currentIndex ++"]
    G --> H{"Còn câu\nhỏi?"}
    H -->|"Hết"| I["📣 Fire sự kiện\nOnQuestionsExhausted"]
    I --> J(["🏁 GameManager\nnhận → GameOver"])
    H -->|"Còn"| K["📣 Fire sự kiện\nOnQuestionChanged (QuestionData)"]
    K --> L["📱 UIController cập nhật\ntext câu hỏi & bộ đếm"]
    K --> M["🖱️ InputController cập nhật\ntext 4 nút đáp án"]
    L & M --> N(["⏳ Chờ người chơi\ntrả lời → NextQuestion()"])
    N --> F

