    G --> H["ScoreManager\n.CheckAnswer(playerId, index)"]
    H --> I{"isCorrect?"}

    I -->|"✅ Đúng"| J["Nút được chọn\n→ Màu Xanh Lá 🟢"]
    I -->|"❌ Sai"| K["Nút được chọn → Đỏ 🔴\nHighlight đáp án đúng → Xanh Lá 🟢"]

    J --> L["📣 Fire OnAnswerSubmitted\n(playerId, index, isCorrect)"]
    K --> L

    L --> M["⏳ Chờ feedbackDuration\n(1 giây)"]
    M --> N["🔄 Reset tất cả nút\nvề màu Navy mặc định"]
    N --> O["🔓 Mở khoá input\n& Enable tất cả nút"]
    O --> P["➡️ QuizManager\n.NextQuestion()"]
    P --> A

